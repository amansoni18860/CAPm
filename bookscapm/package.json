{
  "name": "bookscapm",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xsenv": "^6.2.1",
    "@sap/xssec": "^4.13.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-bookscapmui": "cds watch --open bookscapmui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy bookscapm --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
 
 "cds": {
  "requires": {
    "db": {
      "[production]": {
        "kind": "hana"
      }
    }
  }
}
  ,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/bookscapmui"
  ]
}
